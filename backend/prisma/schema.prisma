generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id        Int        @id @default(autoincrement())
  passcode  String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  teams     Team[]
  questions Question[]
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  score     Float    @default(0)
  roomId    Int?
  bets3x    Int      @default(1)   // 3倍ベット残り回数
  bets2x    Int      @default(2)   // 2倍ベット残り回数
  createdAt DateTime @default(now())

  room      Room?    @relation(fields: [roomId], references: [id])
  answers   Answer[]
}

model Question {
  id            Int      @id @default(autoincrement())
  text          String
  type          String   // "normal", "majority"
  timeLimit     Int      @default(60) // seconds
  correctOption Int?     // for normal questions (1-4)
  roomId        Int?
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())

  room          Room?    @relation(fields: [roomId], references: [id])
  options       Option[]
  answers       Answer[]
}

model Option {
  id         Int      @id @default(autoincrement())
  questionId Int
  text       String
  order      Int
  question   Question @relation(fields: [questionId], references: [id])
}

model Answer {
  id         Int      @id @default(autoincrement())
  teamId     Int
  questionId Int
  optionId   Int
  bet        Int      // 1, 2, or 3
  timeTaken  Float    // seconds
  isCorrect  Boolean?
  points     Float?
  createdAt  DateTime @default(now())

  team       Team     @relation(fields: [teamId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])
}
